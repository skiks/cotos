{
  "name": "cotos",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous Telegram AI/IT channel @cotos — collect, filter, rewrite, publish",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "collect": "tsx src/collectors/rss.ts",
    "collect:tg": "python3 src/collectors/telegram.py",
    "pipeline:batch": "tsx src/pipeline/batch.ts",
    "publish": "tsx src/publisher/telegram.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "better-sqlite3": "^12.11.1",
    "bullmq": "^5.51.0",
    "fastify": "^5.3.0",
    "ioredis": "^5.6.0",
    "js-yaml": "^5.2.1",
    "node-telegram-bot-api": "^1.1.2",
    "openai": "^6.45.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/node-telegram-bot-api": "^0.64.15",
    "prisma": "^6.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
