# COTOS — Autonomous Telegram AI/IT Channel

# ============================
# Server
# ============================
PORT=3100
NODE_ENV=development
LOG_LEVEL=info

# ============================
# Database (PostgreSQL)
# ============================
DATABASE_URL=postgresql://cotos:cotos@localhost:5432/cotos

# ============================
# Redis
# ============================
REDIS_URL=redis://localhost:6379

# ============================
# AI Providers (at least one required)
# ============================
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ============================
# Telegram Bot API (for publishing)
# ============================
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_ADMIN_BOT_TOKEN=123456:ABC-DEF

# ============================
# Telegram Channel
# ============================
CHANNEL_ID=@cotos
ADMIN_CHAT_ID=602562

# ============================
# Telegram User Bridge (for parsing)
# ============================
TG_BRIDGE_URL=http://127.0.0.1:8647

# ============================
# RSS Collector
# ============================
RSS_REFRESH_INTERVAL_MINUTES=15

# ============================
# Scheduler
# ============================
TIMEZONE=Asia/Jakarta
